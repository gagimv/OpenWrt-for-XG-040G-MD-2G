#!/bin/sh /etc/rc.common
# Ensure rpcd starts after ubus and has proper timeout

START=12
STOP=98

USE_PROCD=1
PROG=/usr/sbin/rpcd

start_service() {
    procd_open_instance
    procd_set_param command "$PROG" -s /var/run/ubus/ubus.sock -t 30
    procd_set_param respawn 3600 5 5
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}
