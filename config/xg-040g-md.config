#
# Target
#
CONFIG_TARGET_airoha=y
CONFIG_TARGET_airoha_an7581=y
CONFIG_TARGET_airoha_an7581_DEVICE_bell_xg-040g-md=y
CONFIG_ARCH_64BIT=y
CONFIG_aarch64=y
# Let OpenWrt choose the default kernel version
# CONFIG_LINUX_6_12 is not set
#
# Airoha hardware
#
CONFIG_PACKAGE_airoha-en7581-npu-firmware=y
CONFIG_PACKAGE_kmod-phy-airoha-en8811h=y
CONFIG_PACKAGE_kmod-i2c-an7581=y
#
# Base system ─ 最小核心系统必备组件
#
CONFIG_DEFAULT_base-files=y
CONFIG_DEFAULT_busybox=y
CONFIG_DEFAULT_ca-bundle=y
CONFIG_DEFAULT_logd=y
CONFIG_DEFAULT_procd=y
CONFIG_DEFAULT_uci=y
CONFIG_DEFAULT_urandom-seed=y
CONFIG_DEFAULT_urngd=y
CONFIG_DEFAULT_netifd=y
CONFIG_DEFAULT_mtd=y
CONFIG_DEFAULT_fstools=y
CONFIG_DEFAULT_block-mount=y
CONFIG_DEFAULT_libc=y
CONFIG_DEFAULT_libgcc=y
CONFIG_PACKAGE_uboot-envtools=y
CONFIG_PACKAGE_kmod-ubootenv-nvram=y
CONFIG_PACKAGE_uclient-fetch=y
CONFIG_PACKAGE_kmod-gpio-button-hotplug=y
CONFIG_PACKAGE_kmod-leds-gpio=y
CONFIG_PACKAGE_ubi-utils=y
CONFIG_MTD_UBI=y
CONFIG_UBIFS_FS=y
#
# Network ─ 基础IPv4/IPv6网络栈
#
CONFIG_IPV6=y
CONFIG_DEFAULT_odhcp6c=y
CONFIG_DEFAULT_odhcpd-ipv6only=y
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_nftables=y
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_kmod-nfnetlink=y
CONFIG_PACKAGE_kmod-nft-core=y
CONFIG_PACKAGE_kmod-nft-nat=y
CONFIG_PACKAGE_kmod-nf-flow=y
CONFIG_PACKAGE_kmod-nft-offload=y
CONFIG_PACKAGE_ethtool-full=y
#
# IPv6 增强支持
#
CONFIG_PACKAGE_ipv6helper=y
CONFIG_PACKAGE_6in4=y
CONFIG_PACKAGE_6rd=y
CONFIG_PACKAGE_6to4=y
CONFIG_PACKAGE_ds-lite=y
CONFIG_PACKAGE_map-t=y
#
# 包管理器：apk
#
CONFIG_PACKAGE_apk=y
CONFIG_DEFAULT_apk-tools=y
CONFIG_PACKAGE_apk-mbedtls=y
CONFIG_DEFAULT_openwrt-keyring=y
#
# PPPoE拨号支持
#
CONFIG_PACKAGE_ppp=y
CONFIG_PACKAGE_ppp-mod-pppoe=y
#
# SSH服务
#
CONFIG_PACKAGE_dropbear=y
CONFIG_DROPBEAR_SMALL_CODE=y
CONFIG_DROPBEAR_ED25519=y
CONFIG_DROPBEAR_CURVE25519=y
#
# USB存储支持
#
CONFIG_USB_SUPPORT=y
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb2=y
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb-xhci-hcd=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-uas=y
CONFIG_PACKAGE_kmod-usb-storage-extras=y
#
# 文件系统与extroot支持
#
CONFIG_PACKAGE_fitblk=y
CONFIG_PACKAGE_blkid=y
CONFIG_PACKAGE_lsblk=y
CONFIG_PACKAGE_e2fsprogs=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-fs-exfat=y
CONFIG_PACKAGE_kmod-fs-ext4=y
#
# 文件系统性能优化
#
CONFIG_PACKAGE_kmod-fs-f2fs=y
CONFIG_PACKAGE_f2fs-tools=y
CONFIG_PACKAGE_kmod-fs-btrfs=y
CONFIG_PACKAGE_btrfs-progs=y
#
# NFS 网络存储支持
#
CONFIG_PACKAGE_kmod-fs-nfs=y
CONFIG_PACKAGE_kmod-fs-nfs-v4=y
CONFIG_PACKAGE_nfs-utils=y
#
# Samba 文件共享
#
CONFIG_PACKAGE_samba4-server=y
CONFIG_PACKAGE_luci-app-samba4=y
CONFIG_PACKAGE_luci-i18n-samba4-zh-cn=y
#
# LuCI Web管理界面完整依赖
#
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-ssl=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-mod-admin-full=y
CONFIG_PACKAGE_luci-mod-network=y
CONFIG_PACKAGE_luci-mod-status=y
CONFIG_PACKAGE_luci-mod-system=y
CONFIG_PACKAGE_uhttpd=y
CONFIG_PACKAGE_uhttpd-mod-ubus=y
CONFIG_PACKAGE_rpcd=y
CONFIG_PACKAGE_rpcd-mod-rrdns=y
CONFIG_PACKAGE_rpcd-mod-luci=y
CONFIG_PACKAGE_rpcd-mod-file=y
CONFIG_PACKAGE_rpcd-mod-iwinfo=y
CONFIG_PACKAGE_rpcd-mod-ucode=y
CONFIG_PACKAGE_libubus=y
CONFIG_PACKAGE_libubox=y
CONFIG_PACKAGE_libucode=y
#
# LuCI中文语言包
#
CONFIG_LUCI_LANG_zh_Hans=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y
CONFIG_PACKAGE_luci-i18n-homeproxy-zh-cn=y
CONFIG_PACKAGE_luci-i18n-passwall-zh-cn=y
#
# LuCI主题
#
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y
CONFIG_PACKAGE_luci-theme-bootstrap=y
#
# 系统基础工具
#
CONFIG_PACKAGE_umdns=y
CONFIG_PACKAGE_kmod-mtd-rw=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-ssl=y
CONFIG_PACKAGE_fwtool=y
#
# 代理插件
#
CONFIG_PACKAGE_luci-app-homeproxy=y
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_xray-core=y
#
# 透明代理核心依赖
#
CONFIG_PACKAGE_kmod-nft-tproxy=y
CONFIG_PACKAGE_kmod-nf-socket=y
#
# UPnP 支持
#
CONFIG_PACKAGE_miniupnpd=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-i18n-upnp-zh-cn=y
#
# DDNS 动态域名
#
CONFIG_PACKAGE_ddns-scripts=y
CONFIG_PACKAGE_ddns-scripts-services=y
CONFIG_PACKAGE_luci-app-ddns=y
CONFIG_PACKAGE_luci-i18n-ddns-zh-cn=y
#
# QoS 流量控制（已有 SQM，补充传统 QoS）
#
CONFIG_PACKAGE_qos-scripts=y
CONFIG_PACKAGE_luci-app-qos=y
CONFIG_PACKAGE_luci-i18n-qos-zh-cn=y
#
# KMS 激活服务器
#
CONFIG_PACKAGE_vlmcsd=y
CONFIG_PACKAGE_luci-app-vlmcsd=y
CONFIG_PACKAGE_luci-i18n-vlmcsd-zh-cn=y
#
# 其他常用功能
#
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-i18n-ttyd-zh-cn=y
CONFIG_PACKAGE_luci-app-watchcat=y
CONFIG_PACKAGE_luci-i18n-watchcat-zh-cn=y
CONFIG_PACKAGE_luci-app-wol=y
CONFIG_PACKAGE_luci-i18n-wol-zh-cn=y
#
# 多WAN负载均衡
#
CONFIG_PACKAGE_mwan3=y
CONFIG_PACKAGE_luci-app-mwan3=y
CONFIG_PACKAGE_luci-i18n-mwan3-zh-cn=y
#
# 策略路由
#
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_ipset=y
CONFIG_PACKAGE_iptables-mod-ipopt=y
CONFIG_PACKAGE_iptables-mod-conntrack-extra=y
#
# 动态路由协议
#
CONFIG_PACKAGE_quagga=y
CONFIG_PACKAGE_quagga-zebra=y
CONFIG_PACKAGE_quagga-bgpd=y
CONFIG_PACKAGE_quagga-ospfd=y
#
# ============================================================
# 2GB RAM 专属深度性能优化
# ============================================================
#
# 内存管理与Swap优化
#
CONFIG_KERNEL_SWAP=y
CONFIG_PACKAGE_zram-swap=y
CONFIG_PACKAGE_kmod-zram=y
CONFIG_KERNEL_ZSMALLOC=y
CONFIG_KERNEL_ZRAM_WRITEBACK=y
# 大内存专属：同页合并节省内存
CONFIG_KERNEL_KSM=y
# 大内存专属：透明巨页减少页表开销，提升内存访问性能
CONFIG_KERNEL_TRANSPARENT_HUGEPAGE=y
CONFIG_KERNEL_TRANSPARENT_HUGEPAGE_ALWAYS=y
CONFIG_KERNEL_COMPACTION=y
CONFIG_KERNEL_MIGRATION=y
#
# 网络性能与连接数优化（2GB大内存专属调优）
#
CONFIG_PACKAGE_kmod-nf-conntrack=y
CONFIG_PACKAGE_kmod-nf-conntrack-netlink=y
CONFIG_PACKAGE_kmod-ipt-conntrack=y
CONFIG_PACKAGE_kmod-ipt-conntrack-extra=y
CONFIG_NETFILTER_NETLINK=y
# 大内存专属：完整DNS功能，支持高级缓存/ipset/代理规则
CONFIG_PACKAGE_dnsmasq-full=y
# CONFIG_PACKAGE_dnsmasq is not set
#
# 智能 DNS 加速（SmartDNS）
#
CONFIG_PACKAGE_smartdns=y
CONFIG_PACKAGE_luci-app-smartdns=y
CONFIG_PACKAGE_luci-i18n-smartdns-zh-cn=y
#
# AdGuard Home（可选高级 DNS 方案）
#
CONFIG_PACKAGE_adguardhome=y
CONFIG_PACKAGE_luci-app-adguardhome=y
CONFIG_PACKAGE_luci-i18n-adguardhome-zh-cn=y
#
# 硬件转发加速（AN7581平台专属，榨干硬件性能）
#
CONFIG_PACKAGE_kmod-nf-flow=y
CONFIG_PACKAGE_kmod-nft-offload=y
CONFIG_PACKAGE_kmod-fast-classifier=y
CONFIG_PACKAGE_kmod-shortcut-fe=y
CONFIG_PACKAGE_kmod-shortcut-fe-cm=y
#
# 网络加速增强
#
CONFIG_PACKAGE_kmod-ipt-offload=y
CONFIG_PACKAGE_kmod-tcp-bbr=y
CONFIG_PACKAGE_kmod-sched-core=y
CONFIG_PACKAGE_kmod-sched-cake=y
CONFIG_PACKAGE_kmod-ifb=y
#
# 多队列网络支持
#
CONFIG_PACKAGE_kmod-sched-mqprio=y
CONFIG_PACKAGE_kmod-netem=y
#
# SQM流量整形与QoS（2GB内存无压力承载）
#
CONFIG_PACKAGE_sqm-scripts=y
CONFIG_PACKAGE_luci-app-sqm=y
CONFIG_PACKAGE_luci-i18n-sqm-zh-cn=y
#
# 网络性能监控工具
#
CONFIG_PACKAGE_iperf3=y
CONFIG_PACKAGE_tcpdump=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_iftop=y
CONFIG_PACKAGE_bmon=y
#
# 系统监控增强
#
CONFIG_PACKAGE_collectd=y
CONFIG_PACKAGE_collectd-mod-cpu=y
CONFIG_PACKAGE_collectd-mod-memory=y
CONFIG_PACKAGE_collectd-mod-network=y
CONFIG_PACKAGE_collectd-mod-load=y
CONFIG_PACKAGE_collectd-mod-interface=y
CONFIG_PACKAGE_luci-app-statistics=y
CONFIG_PACKAGE_luci-i18n-statistics-zh-cn=y
#
# 网络诊断工具
#
CONFIG_PACKAGE_mtr=y
CONFIG_PACKAGE_nmap=y
CONFIG_PACKAGE_netperf=y
CONFIG_PACKAGE_speedtest-netperf=y
CONFIG_PACKAGE_bind-dig=y
CONFIG_PACKAGE_bind-host=y
#
# 内核调度与低延迟优化（2GB内存专属）
#
# 完全抢占内核，降低网络/代理延迟
CONFIG_KERNEL_PREEMPT=y
# CONFIG_KERNEL_PREEMPT_VOLUNTARY is not set
# CONFIG_KERNEL_PREEMPT_NONE is not set
CONFIG_KERNEL_SCHED_AUTOGROUP=y
CONFIG_KERNEL_CGROUP_SCHED=y
CONFIG_KERNEL_FAIR_GROUP_SCHED=y
CONFIG_KERNEL_CFS_BANDWIDTH=y
#
# I/O调度器优化（针对NAND闪存专属调优）
#
CONFIG_KERNEL_IOSCHED_BFQ=y
CONFIG_KERNEL_BFQ_GROUP_IOSCHED=y
#
# 高级路由与多线路支持
#
CONFIG_KERNEL_IP_ADVANCED_ROUTER=y
CONFIG_KERNEL_IP_MULTIPLE_TABLES=y
CONFIG_KERNEL_IP_ROUTE_MULTIPATH=y
CONFIG_KERNEL_IP_ROUTE_VERBOSE=y
CONFIG_KERNEL_IP_MROUTE=y
CONFIG_KERNEL_IP_MROUTE_MULTIPLE_TABLES=y
#
# TCP性能优化（大带宽大内存专属，BBR+FQ调度）
#
CONFIG_KERNEL_TCP_CONG_ADVANCED=y
CONFIG_KERNEL_TCP_CONG_BBR=y
CONFIG_KERNEL_NET_SCH_FQ=y
CONFIG_KERNEL_NET_SCH_FQ_CODEL=y
#
# 编译优化配置
#
CONFIG_DEVEL=y
CONFIG_CCACHE=y
CONFIG_CCACHE_DIR="/mnt/openwrt/ccache"
#
# 编译器优化等级（提升性能）
#
CONFIG_TARGET_OPTIONS=y
CONFIG_TARGET_OPTIMIZATION="-O3 -pipe -mcpu=cortex-a53+crypto"
CONFIG_USE_GC_SECTIONS=y
CONFIG_USE_LTO=y
#
# 内核性能优化
#
CONFIG_KERNEL_PERF_EVENTS=y
CONFIG_KERNEL_PROFILING=y
CONFIG_KERNEL_KALLSYMS=y
#
# 高精度定时器（降低延迟）
#
CONFIG_KERNEL_HIGH_RES_TIMERS=y
CONFIG_KERNEL_NO_HZ=y
CONFIG_KERNEL_NO_HZ_IDLE=y
#
# CPU 频率调节
#
CONFIG_PACKAGE_kmod-cpufreq=y
CONFIG_PACKAGE_cpufreq-utils=y
